APP_NAME=Dr. Solution.
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=false
REQUIRE_USER_API_KEY=false

# Optional local fallback keys. Keep real keys out of Git.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

MAX_UPLOAD_MB=15
MAX_TEXT_CHARS=60000
MAX_IMAGES=24
MAX_PAGES=24
ANALYSIS_BATCH_SIZE=4
REQUEST_TIMEOUT_SECONDS=180

# Comma-separated browser origins when the frontend is hosted separately.
ALLOWED_ORIGINS=
