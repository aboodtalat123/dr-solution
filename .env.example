APP_NAME=Dr. Solution.
APP_VERSION=3.2.0
ENVIRONMENT=development
DEBUG=false
REQUIRE_USER_API_KEY=false

# Optional local fallback keys. Keep real keys out of Git.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

MAX_UPLOAD_MB=15
MAX_TEXT_CHARS=60000
MAX_IMAGES=24
MAX_PAGES=24
ANALYSIS_BATCH_SIZE=4
REQUEST_TIMEOUT_SECONDS=180

# Video analysis. The tiny Whisper model is intentional for free CPU hosting.
VIDEO_MAX_DURATION_SECONDS=7200
VIDEO_MAX_PLAYLIST_ITEMS=3
VIDEO_MAX_SEGMENTS=12
VIDEO_MAX_SEGMENT_SECONDS=120
VIDEO_SCENE_THRESHOLD=27
VIDEO_MIN_SCENE_SECONDS=10
VIDEO_ENABLE_SCENE_DETECTION=true
VIDEO_ENABLE_WHISPER=true
VIDEO_WHISPER_MAX_DURATION_SECONDS=1800
WHISPER_MODEL=tiny
WHISPER_COMPUTE_TYPE=int8

# Comma-separated browser origins when the frontend is hosted separately.
ALLOWED_ORIGINS=
